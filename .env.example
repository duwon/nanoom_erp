# 로컬 개발 환경변수 예시
# 사용법: cp .env.example .env

# ── MongoDB ─────────────────────────────────
MONGO_URL=mongodb://mongo:27017
MONGO_DB=nanoom_erp

# ── 인증 ─────────────────────────────────────
JWT_SECRET_KEY=change-me-in-development-only

AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ── 프론트엔드 URL (CORS) ──────────────────────
FRONTEND_APP_URL=http://localhost:3300
CORS_ORIGINS=http://localhost:3300

# ── 프론트엔드 → 백엔드 API ───────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://backend:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/display

# ── OAuth (선택) ──────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# ── 개발용 시드 계정 ────────────────────────────
AUTH_DEV_SEED_ENABLED=true
AUTH_DEV_SEED_PROVIDER=google
AUTH_DEV_SEED_EMAIL=admin@localhost
AUTH_DEV_SEED_PROVIDER_USER_ID=dev-master
AUTH_DEV_SEED_NAME=개발 관리자

# ── 스토리지 ─────────────────────────────────
UDMS_STORAGE_DIR=/app/data/storage
