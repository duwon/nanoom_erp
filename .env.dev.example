# ================================================================
# NAS 개발 서버 환경변수 예시 (dev 브랜치 배포용)
# 사용법: cp .env.dev.example .env.dev 후 직접 수정
# 위치:   /volume1/docker/nanoom-project/.env.dev
# ================================================================

ENV=dev

# 개발 서버는 외부에서 직접 접속하므로 0.0.0.0으로 바인딩합니다.
FRONTEND_BIND_IP=0.0.0.0
BACKEND_BIND_IP=0.0.0.0
FRONTEND_PORT=3300
BACKEND_PORT=8001
# MONGO_PORT=27018  # DB 포트 외부 노출이 필요한 경우에만 사용

FRONTEND_APP_URL=http://erp.nanoom.org:3300

AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

JWT_SECRET_KEY=dev-server-secret-key-change-me

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# 필요 시 개발용 시드 계정 활성화
AUTH_DEV_SEED_ENABLED=false
