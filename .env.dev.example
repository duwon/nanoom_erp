# ================================================================
# NAS 개발 서버 환경변수 (dev 브랜치 배포용)
# 사용법: cp .env.dev.example .env.dev  →  값 직접 수정
# 위치:   /volume1/docker/nanoom-project/.env.dev
# ================================================================

# ── 배포 환경 식별 ─────────────────────────────
ENV=dev

# ── 포트 설정 (prod와 다른 포트로 분리) ────────────
FRONTEND_PORT=3300
BACKEND_PORT=8001
# MONGO_PORT=27018  # DB 포트 외부 노출이 필요한 경우에만 활성화

# ── URL 설정 ──────────────────────────────────
FRONTEND_APP_URL=http://erp.nanoom.org:3300

# ── 인증 쿠키 ─────────────────────────────────
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ── 시크릿 ────────────────────────────────────
JWT_SECRET_KEY=dev-server-secret-key-change-me

# ── OAuth ──────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# ── 개발 서버 시드 계정 (선택) ─────────────────
AUTH_DEV_SEED_ENABLED=false
