# ================================================================
# NAS 프로덕션 환경변수 (main 브랜치 배포용)
# 사용법: cp .env.prod.example .env.prod  →  값 직접 수정
# 위치:   /volume1/docker/nanoom-project/.env.prod
# ================================================================

# ── 배포 환경 식별 ─────────────────────────────
ENV=prod

# ── 포트 설정 ─────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8000
# MONGO_PORT=27017  # DB 포트 외부 노출이 필요한 경우에만 활성화

# ── URL 설정 ──────────────────────────────────
FRONTEND_APP_URL=http://erp.nanoom.org

# ── 인증 쿠키 ─────────────────────────────────
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=erp.nanoom.org

# ── 시크릿 (반드시 변경) ────────────────────────
JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET_AT_LEAST_32_CHARS

# ── OAuth (사용하는 것만 입력) ──────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
