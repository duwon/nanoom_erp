# ================================================================
# NAS 프로덕션 환경변수 예시 (main 브랜치 배포용)
# 사용법: cp .env.prod.example .env.prod 후 직접 수정
# 위치:   /volume1/docker/nanoom-project/.env.prod
#
# 운영 권장 구조:
# - NAS 리버스 프록시가 80/443을 점유
# - frontend 컨테이너는 127.0.0.1:3400
# - backend 컨테이너는 127.0.0.1:8000
# - 프록시가 "/" -> frontend, "/api"와 "/ws" -> backend 전달
# ================================================================

ENV=prod

# 내부 바인딩 포트. 80/443은 NAS 리버스 프록시가 사용하도록 둡니다.
FRONTEND_BIND_IP=127.0.0.1
BACKEND_BIND_IP=127.0.0.1
FRONTEND_PORT=3400
BACKEND_PORT=8000
# MONGO_PORT=27017  # DB 포트 외부 노출이 필요한 경우에만 사용

# 퍼블릭 URL. AUTH_COOKIE_SECURE=true 이면 HTTPS를 사용해야 합니다.
FRONTEND_APP_URL=https://erp.nanoom.org

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=erp.nanoom.org

# 실제 시크릿으로 교체
JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET_AT_LEAST_32_CHARS

# OAuth 사용 시 입력
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
